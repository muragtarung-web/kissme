rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definitions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // Prioritize explicit admin role, fallback to hardcoded dev email for setup
      return isSignedIn() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        request.auth.token.email == 'liebedel7@gmail.com'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Helpers ---

    function isValidUser(data) {
      return data.email is string && data.email.size() > 0 &&
             (data.get('displayName', null) == null || data.displayName is string) &&
             (data.get('photoURL', null) == null || data.photoURL is string) &&
             data.role in ['customer', 'admin', 'staff'] &&
             data.points is number &&
             data.tier in ['Bronze', 'Silver', 'Gold'] &&
             (data.get('createdAt', null) == null || data.createdAt is string);
    }

    function isValidCategory(data) {
      return data.name is string && data.name.size() > 0 &&
             data.order is number &&
             data.active is bool;
    }

    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 &&
             data.price is number &&
             data.categoryId is string &&
             (data.get('description', null) == null || data.description is string) &&
             (data.get('image', null) == null || data.image is string) &&
             (data.get('available', null) == null || data.available is bool) &&
             (data.get('stock', null) == null || data.stock is number) &&
             (data.get('trackInventory', null) == null || data.trackInventory is bool);
    }

    function isValidOrder(data) {
      return (data.customerId == request.auth.uid || data.customerId == 'Terminal') &&
             data.total is number &&
             data.status in ['pending', 'confirmed', 'cooking', 'ready', 'delivery', 'delivered', 'cancelled', 'completed'] &&
             data.items is list &&
             (data.get('type', null) == null || data.type in ['dine-in', 'pickup', 'delivery', 'advance', 'bulk', 'catering', 'Terminal']) &&
             (data.get('paymentMethod', null) == null || data.paymentMethod is string);
    }

    function isValidReservation(data) {
      return data.customerId == request.auth.uid &&
             data.date is string &&
             data.time is string &&
             data.guests is string && // UI sends string like "2" or "1-2"
             data.type in ['table', 'event', 'indoor', 'outdoor'] &&
             data.status in ['pending', 'confirmed', 'cancelled'];
    }

    function isValidEvent(data) {
      return data.title is string && data.title.size() > 0 &&
             data.date is string &&
             data.time is string;
    }

    function isValidNotification(data) {
      return data.userId is string &&
             data.title is string &&
             data.read is bool;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isAdmin() || (
        isOwner(userId) && (
          // Standard users can't change their role
          incoming().role == existing().role &&
          // Standard users can't change their points directly (usually)
          // But allow tier/points for this app's logic if requested.
          // Let's restrict it to profile fields mainly.
          incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'savedAddresses'])
        )
      );
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin() && isValidCategory(incoming());
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin() && isValidProduct(incoming());
    }

    match /orders/{orderId} {
      allow get: if isOwner(existing().customerId) || isAdmin();
      allow list: if isAdmin() || (isSignedIn() && resource.data.customerId == request.auth.uid);
      allow create: if isSignedIn() && isValidOrder(incoming());
      allow update, delete: if isAdmin();
    }

    match /reservations/{resId} {
      allow get: if isOwner(existing().customerId) || isAdmin();
      allow list: if isAdmin() || (isSignedIn() && resource.data.customerId == request.auth.uid);
      allow create: if isSignedIn() && isValidReservation(incoming());
      allow update, delete: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if true;
      allow write: if isAdmin() && isValidEvent(incoming());
    }

    match /moments/{momentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /reminders/{reminderId} {
      allow read, write: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAdmin();
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && 
                   incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
